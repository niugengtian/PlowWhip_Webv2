# Copy this file to .env.local and fill the values locally.
# macOS/Linux: chmod 600 .env.local
# Windows PowerShell:
#   icacls .env.local /inheritance:r /grant:r "$($env:USERNAME):(R,W)"
#
# .env.local is ignored by Git. Never commit a real key.

# Generate with: openssl rand -hex 24
PLOW_WHIP_BRIDGE_TOKEN=

# Optional: enables the built-in DeepSeek simple-worker in the Host Bridge.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# Optional API-compatible endpoint override.
# DEEPSEEK_BASE_URL=https://api.deepseek.com
