# Copy this file to .env.local, fill the values locally, then run:
#   chmod 600 .env.local
#
# .env.local is ignored by Git. Never commit a real key.

# Generate with: openssl rand -hex 24
PLOW_WHIP_BRIDGE_TOKEN=

# Optional: enables the built-in DeepSeek simple-worker in the Host Bridge.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# Optional API-compatible endpoint override.
# DEEPSEEK_BASE_URL=https://api.deepseek.com
